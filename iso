<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Isometric Piping Draft</title>
  <style>
    :root {
      --bg: #181818;
      --panel: #232323;
      --panel-2: #2b2b2b;
      --panel-3: #343434;
      --line: #4c4c4c;
      --text: #e3e3e3;
      --muted: #b2b2b2;
      --accent: #cfcfcf;
      --danger: #9b9b9b;
      --canvas: #141414;
      --grid: rgba(255,255,255,0.06);
      --grid-strong: rgba(255,255,255,0.14);
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; font-family: Inter, Segoe UI, Arial, sans-serif; background: var(--bg); color: var(--text); }

    body {
      display: grid;
      grid-template-columns: 320px 1fr;
      overflow: hidden;
    }

    .sidebar {
      background: linear-gradient(180deg, #212121 0%, #191919 100%);
      border-right: 1px solid #3c3c3c;
      padding: 14px;
      overflow: auto;
    }

    .brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 12px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 10px;
      margin-bottom: 14px;
    }

    .brand h1 {
      font-size: 15px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin: 0;
    }

    .brand small {
      color: var(--muted);
      display: block;
      margin-top: 3px;
      letter-spacing: 0.08em;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 12px;
      margin-bottom: 12px;
    }

    .card h2 {
      font-size: 12px;
      margin: 0 0 10px;
      color: #f0f0f0;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 8px;
    }

    .row.single { grid-template-columns: 1fr; }

    label {
      display: block;
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    input, button, select {
      width: 100%;
      border-radius: 8px;
      border: 1px solid #4b4b4b;
      background: var(--panel-2);
      color: var(--text);
      padding: 9px 10px;
      font-size: 13px;
      outline: none;
    }

    input[type="range"] {
      padding: 0;
      background: transparent;
      border: none;
    }

    button {
      cursor: pointer;
      background: linear-gradient(180deg, #3a3a3a 0%, #2e2e2e 100%);
      transition: transform 0.05s ease, filter 0.15s ease;
    }
    button:hover { filter: brightness(1.08); }
    button:active { transform: translateY(1px); }

    .primary {
      background: linear-gradient(180deg, #565656 0%, #404040 100%);
      color: #fff;
    }

    .toolbar-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .stat {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      padding: 6px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .stat:last-child { border-bottom: none; }

    .hint {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.45;
      margin-top: 8px;
    }

    .main {
      position: relative;
      background: radial-gradient(circle at 30% 20%, #1f1f1f 0%, #151515 55%, #111 100%);
      overflow: hidden;
    }

    #canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      background: var(--canvas);
      cursor: crosshair;
    }

    .overlay {
      position: absolute;
      top: 14px;
      right: 14px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      pointer-events: none;
    }

    .badge {
      background: rgba(25,25,25,0.85);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #efefef;
      box-shadow: 0 8px 22px rgba(0,0,0,0.24);
    }

    .north-indicator {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .north-indicator svg {
      width: 68px;
      height: 68px;
      overflow: visible;
    }

    .status-bar {
      position: absolute;
      left: 14px;
      bottom: 14px;
      background: rgba(25,25,25,0.85);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 12px;
      color: #efefef;
      letter-spacing: 0.04em;
      box-shadow: 0 8px 22px rgba(0,0,0,0.24);
      max-width: min(780px, calc(100vw - 380px));
      line-height: 1.5;
    }

    .mono { font-family: Consolas, Menlo, monospace; }

    #printSheet {
      display: none;
      background: white;
      color: black;
    }

    .print-page {
      width: 11in;
      height: 8.5in;
      position: relative;
      margin: 0 auto;
      background: white;
      overflow: hidden;
      color: #111;
      font-family: Arial, Helvetica, sans-serif;
    }

    .print-border {
      position: absolute;
      inset: 0.25in;
      border: 1.5px solid #111;
    }

    .print-title {
      position: absolute;
      right: 0.25in;
      bottom: 0.25in;
      width: 4.35in;
      height: 1.25in;
      border: 1.5px solid #111;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 0.42in 0.42in 0.41in;
      font-size: 10px;
      background: white;
    }

    .print-title > div {
      border-right: 1px solid #111;
      border-bottom: 1px solid #111;
      padding: 5px 6px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 3px;
    }

    .print-title > div:nth-child(3n) { border-right: none; }
    .print-title > div:nth-last-child(-n+3) { border-bottom: none; }

    .title-label {
      font-size: 8px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #444;
    }

    .title-value {
      font-weight: 700;
      font-size: 10px;
      word-break: break-word;
    }

    .drawing-field {
      grid-column: span 2;
    }

    .sheet-header {
      position: absolute;
      left: 0.45in;
      top: 0.33in;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .sheet-sub {
      position: absolute;
      left: 0.45in;
      top: 0.58in;
      font-size: 9px;
      color: #555;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    #printSvgWrap {
      position: absolute;
      left: 0.42in;
      right: 0.42in;
      top: 0.9in;
      bottom: 1.7in;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    #printSvgWrap svg {
      width: 100%;
      height: 100%;
      display: block;
      background: white;
    }

    @media (max-width: 980px) {
      body { grid-template-columns: 1fr; }
      .sidebar {
        position: absolute;
        z-index: 5;
        width: min(92vw, 340px);
        max-height: calc(100vh - 16px);
        left: 8px;
        top: 8px;
        border-radius: 12px;
        border: 1px solid #434343;
        box-shadow: 0 16px 40px rgba(0,0,0,0.4);
      }
      .status-bar { max-width: calc(100vw - 30px); }
    }

    @media print {
      body { display: block; background: white !important; }
      .sidebar, .main { display: none !important; }
      #printSheet { display: block !important; }
      @page { size: landscape letter; margin: 0; }
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="brand">
      <div>
        <h1>Isometric Piping Draft</h1>
        <small>Dark engineering sketch environment</small>
      </div>
    </div>

    <section class="card">
      <h2>Controls</h2>
      <div class="toolbar-grid">
        <button class="primary" id="lineBtn">Line</button>
        <button id="polylineBtn">Polyline</button>
        <button id="undoBtn">Undo</button>
        <button id="clearBtn">Clear</button>
        <button id="centerBtn">Recenter</button>
        <button id="printBtn">Print Sheet</button>
      </div>
      <div class="hint">
        Select <span class="mono">Line</span> or <span class="mono">Polyline</span>. The selected tool stays active. In Line mode, click point A then point B to place one 3D pipe section. In Polyline mode, the run begins on the first click and continues with each click until you press <span class="mono">Enter</span>. The software automatically snaps to the nearest isometric axis.
      </div>
    </section>

    <section class="card">
      <h2>Pipe Settings</h2>
      <div class="row single">
        <div>
          <label for="pipeSize">Current Pipe Size (screen weight)</label>
          <input type="range" id="pipeSize" min="1" max="42" step="1" value="18" />
        </div>
      </div>
      <div class="row">
        <div>
          <label for="pipeSizeValue">Pipe Size</label>
          <input id="pipeSizeValue" type="number" min="1" max="42" step="1" value="18" />
        </div>
        <div>
          <label for="polylineStyle">Polyline Fitting Style</label>
          <select id="polylineStyle">
            <option value="short">Short Radius Elbow</option>
            <option value="long">Long Radius Elbow</option>
          </select>
        </div>
      </div>
      <div class="row">
        <div>
          <label for="gridStep">Grid Step</label>
          <input id="gridStep" type="number" min="8" max="80" step="1" value="24" />
        </div>
        <div>
          <label for="routeModeInfo">Selected Style</label>
          <input id="routeModeInfo" type="text" value="Short Radius Elbow" readonly />
        </div>
      </div>
      <div class="row">
        <div>
          <label for="zoomInfo">Zoom</label>
          <input id="zoomInfo" type="text" value="100%" readonly />
        </div>
        <div>
          <label for="segmentCount">Segments</label>
          <input id="segmentCount" type="text" value="0" readonly />
        </div>
      </div>
      <div class="hint">
        Mouse wheel zooms. Hold the middle mouse button to pan. Each run keeps the pipe size and tool settings that were active when it was started. Line mode places one single 3D pipe section from point A to point B. Polyline mode uses the selected elbow fitting style.
      </div>
    </section>

    <section class="card">
      <h2>Drawing Sheet</h2>
      <div class="row">
        <div>
          <label for="projectTitle">Project</label>
          <input id="projectTitle" type="text" value="ISOMETRIC PIPING" />
        </div>
        <div>
          <label for="drawingNumber">Drawing No.</label>
          <input id="drawingNumber" type="text" value="ISO-001" />
        </div>
      </div>
      <div class="row">
        <div>
          <label for="revision">Revision</label>
          <input id="revision" type="text" value="0" />
        </div>
        <div>
          <label for="sheetScale">Scale</label>
          <input id="sheetScale" type="text" value="NTS" />
        </div>
      </div>
      <div class="row single">
        <div>
          <label for="drawnBy">Drawn By</label>
          <input id="drawnBy" type="text" value="USER" />
        </div>
      </div>
    </section>

    <section class="card">
      <h2>Status</h2>
      <div class="stat"><span>Tool</span><strong id="modeText">Line</strong></div>
      <div class="stat"><span>Routing</span><strong id="routeText">Line</strong></div>
      <div class="stat"><span>North</span><strong>Fixed to top-right</strong></div>
      <div class="stat"><span>Theme</span><strong>Dark grayscale</strong></div>
      <div class="stat"><span>Polyline</span><strong>Ends on Enter</strong></div>
      <div class="hint">
        This first build is focused on isometric piping layout. A future piping component library can be layered on top of this data model without changing the drawing workflow.
      </div>
    </section>
  </aside>

  <main class="main">
    <canvas id="canvas"></canvas>

    <div class="overlay">
      <div class="badge north-indicator">
        <svg viewBox="0 0 80 80" aria-hidden="true">
          <defs>
            <marker id="arrowHead" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
              <path d="M0,0 L8,4 L0,8 Z" fill="#f1f1f1"></path>
            </marker>
          </defs>
          <circle cx="40" cy="40" r="26" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"></circle>
          <path d="M24 50 L57 31" stroke="#f1f1f1" stroke-width="2" marker-end="url(#arrowHead)"></path>
          <text x="58" y="24" fill="#f1f1f1" font-size="11" font-weight="700" text-anchor="middle">N</text>
        </svg>
        <div>
          <div>North</div>
          <div class="mono" style="color:#bdbdbd; margin-top:2px;">Top-right fixed</div>
        </div>
      </div>
      <div class="badge mono" id="cursorReadout">N-GRID: 0  E-GRID: 0  AXIS: N</div>
    </div>

    <div class="status-bar" id="statusBar">
      Ready. Select <span class="mono">Line</span> or <span class="mono">Polyline</span>. In Polyline mode, the run begins on the first click and ends when you press <span class="mono">Enter</span>.
    </div>
  </main>

  <section id="printSheet">
    <div class="print-page">
      <div class="print-border"></div>
      <div class="sheet-header">Isometric Piping Drawing</div>
      <div class="sheet-sub">Professional engineering print format</div>
      <div id="printSvgWrap"></div>
      <div class="print-title">
        <div class="drawing-field">
          <span class="title-label">Project</span>
          <span class="title-value" id="tbProject">ISOMETRIC PIPING</span>
        </div>
        <div>
          <span class="title-label">Rev</span>
          <span class="title-value" id="tbRev">0</span>
        </div>
        <div>
          <span class="title-label">Drawing No.</span>
          <span class="title-value" id="tbDwg">ISO-001</span>
        </div>
        <div>
          <span class="title-label">Scale</span>
          <span class="title-value" id="tbScale">NTS</span>
        </div>
        <div>
          <span class="title-label">Date</span>
          <span class="title-value" id="tbDate">-</span>
        </div>
        <div>
          <span class="title-label">Drawn By</span>
          <span class="title-value" id="tbBy">USER</span>
        </div>
      </div>
    </div>
  </section>

  <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');

    const axes = {
      north: { x: Math.cos(Math.PI / 6), y: -Math.sin(Math.PI / 6), label: 'N' },
      east:  { x: Math.cos(Math.PI / 6), y:  Math.sin(Math.PI / 6), label: 'E' },
      up:    { x: 0, y: -1, label: 'Z' }
    };
    const axisList = [axes.north, axes.east, axes.up];

    const state = {
      segments: [],
      isDrawing: false,
      currentPolylineStart: null,
      previewEnd: null,
      camera: { x: 0, y: 0, zoom: 1 },
      panning: false,
      lastPan: null,
      gridStep: 24,
      defaultPipeSize: 18,
      hoverWorld: { x: 0, y: 0 },
      snappedHover: { x: 0, y: 0 },
      lastSnapAxis: axes.north,
      polylineStartIndex: 0,
      polylineSeedPoint: null,
      toolMode: 'line',
      selectedPolylineStyle: 'short',
      currentPolylineStyle: 'short',
      nextPolylineId: 1,
      activePolylineId: null
    };

    const els = {
      lineBtn: document.getElementById('lineBtn'),
      polylineBtn: document.getElementById('polylineBtn'),
      undoBtn: document.getElementById('undoBtn'),
      clearBtn: document.getElementById('clearBtn'),
      centerBtn: document.getElementById('centerBtn'),
      printBtn: document.getElementById('printBtn'),
      pipeSize: document.getElementById('pipeSize'),
      pipeSizeValue: document.getElementById('pipeSizeValue'),
      gridStep: document.getElementById('gridStep'),
      polylineStyle: document.getElementById('polylineStyle'),
      routeModeInfo: document.getElementById('routeModeInfo'),
      zoomInfo: document.getElementById('zoomInfo'),
      segmentCount: document.getElementById('segmentCount'),
      modeText: document.getElementById('modeText'),
      routeText: document.getElementById('routeText'),
      statusBar: document.getElementById('statusBar'),
      cursorReadout: document.getElementById('cursorReadout'),
      projectTitle: document.getElementById('projectTitle'),
      drawingNumber: document.getElementById('drawingNumber'),
      revision: document.getElementById('revision'),
      sheetScale: document.getElementById('sheetScale'),
      drawnBy: document.getElementById('drawnBy'),
      printSvgWrap: document.getElementById('printSvgWrap'),
      tbProject: document.getElementById('tbProject'),
      tbRev: document.getElementById('tbRev'),
      tbDwg: document.getElementById('tbDwg'),
      tbScale: document.getElementById('tbScale'),
      tbDate: document.getElementById('tbDate'),
      tbBy: document.getElementById('tbBy')
    };

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    }

    function worldToScreen(p) {
      return {
        x: canvas.clientWidth / 2 + (p.x + state.camera.x) * state.camera.zoom,
        y: canvas.clientHeight / 2 + (p.y + state.camera.y) * state.camera.zoom
      };
    }

    function screenToWorld(p) {
      return {
        x: (p.x - canvas.clientWidth / 2) / state.camera.zoom - state.camera.x,
        y: (p.y - canvas.clientHeight / 2) / state.camera.zoom - state.camera.y
      };
    }

    function dot(a, b) { return a.x * b.x + a.y * b.y; }
    function sub(a, b) { return { x: a.x - b.x, y: a.y - b.y }; }
    function add(a, b) { return { x: a.x + b.x, y: a.y + b.y }; }
    function mul(a, s) { return { x: a.x * s, y: a.y * s }; }
    function len(v) { return Math.hypot(v.x, v.y); }
    function norm(v) { const l = len(v) || 1; return { x: v.x / l, y: v.y / l }; }
    function perp(v) { return { x: -v.y, y: v.x }; }
    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
    function almostEqual(a, b, eps = 0.001) { return Math.abs(a - b) <= eps; }
    function samePoint(a, b, eps = 0.001) { return almostEqual(a.x, b.x, eps) && almostEqual(a.y, b.y, eps); }

    function solvePlaneCoefficients(world) {
      const det = axes.north.x * axes.east.y - axes.north.y * axes.east.x;
      const nCoeff = (world.x * axes.east.y - world.y * axes.east.x) / det;
      const eCoeff = (-world.x * axes.north.y + world.y * axes.north.x) / det;
      return { nCoeff, eCoeff };
    }

    function snapPointToIsoGrid(world) {
      const step = state.gridStep;
      const { nCoeff, eCoeff } = solvePlaneCoefficients(world);
      const n = Math.round(nCoeff / step) * step;
      const e = Math.round(eCoeff / step) * step;
      return add(mul(axes.north, n), mul(axes.east, e));
    }

    function inferIsoCoordinates(world) {
      const { nCoeff, eCoeff } = solvePlaneCoefficients(world);
      return {
        n: Math.round(nCoeff / state.gridStep),
        e: Math.round(eCoeff / state.gridStep)
      };
    }

    function snapAlongNearestAxis(anchor, world) {
      const raw = sub(world, anchor);
      let bestAxis = axisList[0];
      let bestProj = 0;
      let bestAbs = -Infinity;
      for (const axis of axisList) {
        const projection = dot(raw, axis);
        const mag = Math.abs(projection);
        if (mag > bestAbs) {
          bestAbs = mag;
          bestProj = projection;
          bestAxis = axis;
        }
      }
      const step = state.gridStep;
      const snappedLength = Math.round(bestProj / step) * step;
      const end = add(anchor, mul(bestAxis, snappedLength));
      state.lastSnapAxis = bestAxis;
      return end;
    }

    function setStatus(text) {
      els.statusBar.innerHTML = text;
    }

    function styleLabel(style) {
      return style === 'long' ? 'Long Radius Elbow' : 'Short Radius Elbow';
    }

    function currentRouteLabel() {
      return state.toolMode === 'line' ? 'Line' : styleLabel(state.selectedPolylineStyle);
    }

    function updateToolButtons() {
      els.lineBtn.classList.toggle('primary', state.toolMode === 'line');
      els.polylineBtn.classList.toggle('primary', state.toolMode === 'polyline');
      els.polylineStyle.disabled = state.toolMode === 'line';
      els.routeModeInfo.value = currentRouteLabel();
    }

    function updateUi() {
      els.pipeSize.value = state.defaultPipeSize;
      els.pipeSizeValue.value = state.defaultPipeSize;
      els.gridStep.value = state.gridStep;
      els.polylineStyle.value = state.selectedPolylineStyle;
      updateToolButtons();
      els.zoomInfo.value = Math.round(state.camera.zoom * 100) + '%';
      els.segmentCount.value = String(state.segments.length);
      if (state.isDrawing) {
        els.modeText.textContent = state.toolMode === 'line' ? 'Drawing Line' : 'Drawing Polyline';
        els.routeText.textContent = state.toolMode === 'line' ? 'Line' : styleLabel(state.currentPolylineStyle);
      } else {
        els.modeText.textContent = state.toolMode === 'line' ? 'Line' : 'Polyline';
        els.routeText.textContent = currentRouteLabel();
      }
      const c = inferIsoCoordinates(state.snappedHover || { x: 0, y: 0 });
      els.cursorReadout.textContent = `N-GRID: ${c.n}  E-GRID: ${c.e}  AXIS: ${state.lastSnapAxis.label}`;
    }

    function drawGrid() {
      const extent = 220;
      const step = state.gridStep;
      const center = { x: 0, y: 0 };

      for (let i = -extent; i <= extent; i++) {
        const offset = i * step;
        drawInfiniteGridLine(add(center, mul(axes.north, offset)), axes.east, i % 5 === 0);
        drawInfiniteGridLine(add(center, mul(axes.east, offset)), axes.north, i % 5 === 0);
        drawInfiniteGridLine(add(center, mul(axes.up, offset)), axes.north, false);
      }
    }

    function drawInfiniteGridLine(point, dir, strong = false) {
      const a = add(point, mul(dir, -20000));
      const b = add(point, mul(dir, 20000));
      const A = worldToScreen(a);
      const B = worldToScreen(b);
      ctx.beginPath();
      ctx.moveTo(A.x, A.y);
      ctx.lineTo(B.x, B.y);
      ctx.lineWidth = strong ? 1.1 : 0.8;
      ctx.strokeStyle = strong ? 'rgba(255,255,255,0.11)' : 'rgba(255,255,255,0.05)';
      ctx.stroke();
    }

    function buildRenderModel(segments) {
      const plans = segments.map(seg => ({
        startTrim: 0,
        endTrim: 0,
        capStart: true,
        capEnd: true
      }));
      const elbows = [];

      for (let i = 1; i < segments.length; i++) {
        const prev = segments[i - 1];
        const curr = segments[i];
        if (!samePoint(prev.end, curr.start)) continue;
        if (prev.polylineId !== curr.polylineId || prev.style !== curr.style || prev.style === 'line') continue;

        const joint = prev.end;
        const awayPrev = norm(sub(prev.start, joint));
        const awayCurr = norm(sub(curr.end, joint));
        const cross = awayPrev.x * awayCurr.y - awayPrev.y * awayCurr.x;
        const prevLen = len(sub(prev.end, prev.start));
        const currLen = len(sub(curr.end, curr.start));

        plans[i - 1].capEnd = false;
        plans[i].capStart = false;

        if (Math.abs(cross) < 0.0001) continue;

        const trimFactor = prev.style === 'long' ? 1.65 : 1.05;
        const trim = Math.max(
          0.5,
          Math.min(Math.min(prev.size, curr.size) * trimFactor, prevLen * 0.42, currLen * 0.42)
        );

        plans[i - 1].endTrim = Math.max(plans[i - 1].endTrim, trim);
        plans[i].startTrim = Math.max(plans[i].startTrim, trim);

        elbows.push({
          joint: { ...joint },
          from: add(joint, mul(awayPrev, trim)),
          to: add(joint, mul(awayCurr, trim)),
          size: Math.min(prev.size, curr.size),
          style: prev.style,
          startDir: mul(awayPrev, -1),
          endDir: awayCurr
        });
      }

      return { plans, elbows };
    }

    function getTrimmedSegment(segment, plan) {
      const dir = norm(sub(segment.end, segment.start));
      const inv = mul(dir, -1);
      const start = plan.startTrim > 0 ? add(segment.start, mul(dir, plan.startTrim)) : segment.start;
      const end = plan.endTrim > 0 ? add(segment.end, mul(inv, plan.endTrim)) : segment.end;
      if (len(sub(end, start)) < 0.001) return null;
      return {
        start,
        end,
        size: segment.size,
        capStart: plan.capStart,
        capEnd: plan.capEnd
      };
    }

    function drawSingleLineSegment(segment, alpha = 1) {
      const a = worldToScreen(segment.start);
      const b = worldToScreen(segment.end);
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.lineWidth = Math.max(1.8, state.camera.zoom * 1.35);
      ctx.strokeStyle = 'rgba(235,235,235,0.92)';
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.lineWidth = Math.max(0.8, state.camera.zoom * 0.45);
      ctx.strokeStyle = 'rgba(0,0,0,0.45)';
      ctx.stroke();
      ctx.restore();
    }

    function elbowBezierControls(elbow, alreadyScreen = false) {
      const p1 = alreadyScreen ? elbow.from : worldToScreen(elbow.from);
      const pc = alreadyScreen ? elbow.joint : worldToScreen(elbow.joint);
      const p2 = alreadyScreen ? elbow.to : worldToScreen(elbow.to);
      const d1 = norm(sub(pc, p1));
      const d2 = norm(sub(p2, pc));
      const turnAngle = Math.acos(clamp(dot(d1, d2), -1, 1));
      if (!Number.isFinite(turnAngle) || turnAngle < 0.001 || Math.PI - turnAngle < 0.001) {
        return { p1, p2, c1: p1, c2: p2, d1, d2, valid: false };
      }
      const tangentRun = (len(sub(pc, p1)) + len(sub(p2, pc))) / 2;
      const radius = tangentRun / Math.tan(turnAngle / 2);
      const handle = (4 / 3) * radius * Math.tan(turnAngle / 4);
      return {
        p1,
        p2,
        c1: add(p1, mul(d1, handle)),
        c2: add(p2, mul(d2, -handle)),
        d1,
        d2,
        valid: true
      };
    }

    function drawPipeSegment(segment, alpha = 1) {
      const a = worldToScreen(segment.start);
      const b = worldToScreen(segment.end);
      const v = sub(b, a);
      const L = len(v);
      if (L < 0.001) return;

      const t = norm(v);
      const n = perp(t);
      const r = (segment.size * state.camera.zoom) / 2;

      const p1 = add(a, mul(n, r));
      const p2 = add(b, mul(n, r));
      const p3 = add(b, mul(n, -r));
      const p4 = add(a, mul(n, -r));

      ctx.save();
      ctx.globalAlpha = alpha;

      const body = ctx.createLinearGradient(p1.x, p1.y, p4.x, p4.y);
      body.addColorStop(0, 'rgba(235,235,235,0.92)');
      body.addColorStop(0.3, 'rgba(198,198,198,0.95)');
      body.addColorStop(0.7, 'rgba(150,150,150,0.98)');
      body.addColorStop(1, 'rgba(88,88,88,1)');

      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.lineTo(p2.x, p2.y);
      ctx.lineTo(p3.x, p3.y);
      ctx.lineTo(p4.x, p4.y);
      ctx.closePath();
      ctx.fillStyle = body;
      ctx.fill();

      ctx.lineWidth = Math.max(1.1, state.camera.zoom * 0.9);
      ctx.strokeStyle = 'rgba(18,18,18,0.72)';
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.lineTo(p2.x, p2.y);
      ctx.lineWidth = Math.max(1.2, state.camera.zoom * 0.9);
      ctx.strokeStyle = 'rgba(255,255,255,0.62)';
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(p4.x, p4.y);
      ctx.lineTo(p3.x, p3.y);
      ctx.lineWidth = Math.max(1.2, state.camera.zoom * 0.9);
      ctx.strokeStyle = 'rgba(0,0,0,0.42)';
      ctx.stroke();

      if (segment.capStart) drawEndCap(a, t, r, alpha);
      if (segment.capEnd) drawEndCap(b, t, r, alpha);

      ctx.restore();
    }

    function drawElbow(elbow, alpha = 1) {
      const { p1, p2, c1, c2, d1, d2 } = elbowBezierControls(elbow, false);
      let bisector = add(perp(d1), perp(d2));
      if (len(bisector) < 0.001) bisector = perp(norm(sub(p2, p1)));
      bisector = norm(bisector);
      const normal = perp(bisector);
      const r = (elbow.size * state.camera.zoom) / 2;

      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.bezierCurveTo(c1.x, c1.y, c2.x, c2.y, p2.x, p2.y);
      ctx.lineWidth = Math.max(2, r * 2 + Math.max(1.2, state.camera.zoom * 0.9));
      ctx.strokeStyle = 'rgba(18,18,18,0.72)';
      ctx.stroke();

      const midX = (p1.x + p2.x + c1.x + c2.x) / 4;
      const midY = (p1.y + p2.y + c1.y + c2.y) / 4;
      const body = ctx.createLinearGradient(
        midX + normal.x * r,
        midY + normal.y * r,
        midX - normal.x * r,
        midY - normal.y * r
      );
      body.addColorStop(0, 'rgba(235,235,235,0.95)');
      body.addColorStop(0.32, 'rgba(198,198,198,0.98)');
      body.addColorStop(0.72, 'rgba(148,148,148,0.98)');
      body.addColorStop(1, 'rgba(88,88,88,1)');

      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.bezierCurveTo(c1.x, c1.y, c2.x, c2.y, p2.x, p2.y);
      ctx.lineWidth = Math.max(1, r * 2);
      ctx.strokeStyle = body;
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.bezierCurveTo(c1.x, c1.y, c2.x, c2.y, p2.x, p2.y);
      ctx.lineWidth = Math.max(1, r * 0.38);
      ctx.strokeStyle = 'rgba(255,255,255,0.22)';
      ctx.stroke();

      ctx.restore();
    }

    function drawEndCap(center, tangent, radius, alpha = 1) {
      const angle = Math.atan2(tangent.y, tangent.x);
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.translate(center.x, center.y);
      ctx.rotate(angle);
      ctx.beginPath();
      ctx.ellipse(0, 0, radius, Math.max(3, radius * 0.45), 0, 0, Math.PI * 2);
      const cap = ctx.createLinearGradient(0, -radius, 0, radius);
      cap.addColorStop(0, 'rgba(250,250,250,0.75)');
      cap.addColorStop(0.55, 'rgba(170,170,170,0.95)');
      cap.addColorStop(1, 'rgba(90,90,90,1)');
      ctx.fillStyle = cap;
      ctx.fill();
      ctx.lineWidth = 1;
      ctx.strokeStyle = 'rgba(18,18,18,0.68)';
      ctx.stroke();
      ctx.restore();
    }

    function drawJointBubble(point, size) {
      const p = worldToScreen(point);
      const r = (size * state.camera.zoom) * 0.44;
      if (r < 2) return;
      ctx.save();
      ctx.beginPath();
      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
      const fill = ctx.createRadialGradient(p.x - r * 0.25, p.y - r * 0.35, r * 0.2, p.x, p.y, r);
      fill.addColorStop(0, 'rgba(245,245,245,0.95)');
      fill.addColorStop(0.5, 'rgba(170,170,170,0.96)');
      fill.addColorStop(1, 'rgba(88,88,88,1)');
      ctx.fillStyle = fill;
      ctx.fill();
      ctx.lineWidth = 1;
      ctx.strokeStyle = 'rgba(18,18,18,0.72)';
      ctx.stroke();
      ctx.restore();
    }

    function render() {
      ctx.clearRect(0, 0, canvas.clientWidth, canvas.clientHeight);

      // Background wash
      const bg = ctx.createLinearGradient(0, 0, 0, canvas.clientHeight);
      bg.addColorStop(0, '#1a1a1a');
      bg.addColorStop(1, '#111');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, canvas.clientWidth, canvas.clientHeight);

      drawGrid();

      // Axes marker at drawing origin
      drawOriginMarker();

      const renderModel = buildRenderModel(state.segments);

      // Pipes
      state.segments.forEach((seg, index) => {
        const trimmed = getTrimmedSegment(seg, renderModel.plans[index]);
        if (trimmed) drawPipeSegment(trimmed, 1);
      });

      // Elbows
      renderModel.elbows.forEach(elbow => drawElbow(elbow, 1));

      // Preview
      if (state.isDrawing && state.currentPolylineStart && state.previewEnd) {
        const previewSegment = {
          start: state.currentPolylineStart,
          end: state.previewEnd,
          size: state.defaultPipeSize,
          style: state.currentPolylineStyle
        };
        drawPipeSegment(previewSegment, 0.72);
        const anchor = worldToScreen(state.currentPolylineStart);
        ctx.beginPath();
        ctx.arc(anchor.x, anchor.y, 4, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.85)';
        ctx.fill();
      } else if (!state.isDrawing && state.snappedHover) {
        const p = worldToScreen(state.snappedHover);
        ctx.beginPath();
        ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.35)';
        ctx.fill();
      }

      updateUi();
    }

    function drawOriginMarker() {
      const o = worldToScreen({ x: 0, y: 0 });
      const lengthPx = 54;
      ctx.save();
      ctx.translate(o.x, o.y);
      ctx.lineWidth = 1.4;
      ctx.strokeStyle = 'rgba(255,255,255,0.38)';
      ctx.fillStyle = 'rgba(255,255,255,0.75)';
      for (const axis of axisList) {
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.lineTo(axis.x * lengthPx, axis.y * lengthPx);
        ctx.stroke();
      }
      ctx.beginPath();
      ctx.arc(0, 0, 3, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function beginPolyline(atWorld) {
      state.isDrawing = true;
      state.currentPolylineStyle = state.toolMode === 'line' ? 'line' : state.selectedPolylineStyle;
      state.activePolylineId = state.nextPolylineId++;
      state.currentPolylineStart = snapPointToIsoGrid(atWorld);
      state.polylineSeedPoint = { ...state.currentPolylineStart };
      state.polylineStartIndex = state.segments.length;
      state.previewEnd = state.currentPolylineStart;
      setStatus(
        state.toolMode === 'line'
          ? 'Line tool active. Move the cursor and click point B to place one 3D pipe section.'
          : `Polyline active in <span class="mono">${styleLabel(state.currentPolylineStyle).toUpperCase()}</span> mode. Move the cursor and click to add continuous pipe segments. Press <span class="mono">Enter</span> to end the current run.`
      );
      render();
    }

    function finishPolyline(message = 'Polyline finished. Select Line or Polyline and click on the canvas to continue drawing. The print sheet will center the completed geometry automatically.') {
      state.isDrawing = false;
      state.currentPolylineStart = null;
      state.previewEnd = null;
      state.polylineSeedPoint = null;
      state.activePolylineId = null;
      setStatus(message);
      render();
    }

    function addSegment(endWorld) {
      if (!state.currentPolylineStart) return;
      const snappedEnd = snapAlongNearestAxis(state.currentPolylineStart, endWorld);
      if (snappedEnd.x === state.currentPolylineStart.x && snappedEnd.y === state.currentPolylineStart.y) return;
      state.segments.push({
        start: { ...state.currentPolylineStart },
        end: { ...snappedEnd },
        size: state.defaultPipeSize,
        style: state.currentPolylineStyle,
        polylineId: state.activePolylineId
      });
      state.currentPolylineStart = snappedEnd;
      state.previewEnd = snappedEnd;
      const justAddedStyle = state.currentPolylineStyle;
      const axisLabel = state.lastSnapAxis.label === 'Z' ? 'vertical' : state.lastSnapAxis.label === 'N' ? 'north' : 'east';
      if (state.toolMode === 'line') {
        finishPolyline(`Single 3D pipe section placed along the ${axisLabel} isometric axis using the <span class="mono">LINE</span> tool.`);
        return;
      }
      setStatus(`Segment added along the ${axisLabel} isometric axis using <span class="mono">${styleLabel(justAddedStyle).toUpperCase()}</span> mode. Continue clicking to extend the pipe run, then press <span class="mono">Enter</span> to end it.`);
      render();
    }

    function recenter() {
      if (!state.segments.length) {
        state.camera.x = 0;
        state.camera.y = 0;
        state.camera.zoom = 1;
        render();
        return;
      }
      const pts = [];
      for (const s of state.segments) { pts.push(s.start, s.end); }
      const minX = Math.min(...pts.map(p => p.x));
      const maxX = Math.max(...pts.map(p => p.x));
      const minY = Math.min(...pts.map(p => p.y));
      const maxY = Math.max(...pts.map(p => p.y));
      const cx = (minX + maxX) / 2;
      const cy = (minY + maxY) / 2;
      const width = Math.max(100, maxX - minX);
      const height = Math.max(100, maxY - minY);
      const zoomX = (canvas.clientWidth * 0.72) / width;
      const zoomY = (canvas.clientHeight * 0.72) / height;
      state.camera.zoom = clamp(Math.min(zoomX, zoomY), 0.25, 3.8);
      state.camera.x = -cx;
      state.camera.y = -cy;
      render();
    }

    function updatePreviewFromPointer(clientX, clientY) {
      const rect = canvas.getBoundingClientRect();
      const world = screenToWorld({ x: clientX - rect.left, y: clientY - rect.top });
      state.hoverWorld = world;
      state.snappedHover = snapPointToIsoGrid(world);
      if (state.isDrawing && state.currentPolylineStart) {
        state.previewEnd = snapAlongNearestAxis(state.currentPolylineStart, world);
      }
      render();
    }

    function pointerPosition(evt) {
      const rect = canvas.getBoundingClientRect();
      return { x: evt.clientX - rect.left, y: evt.clientY - rect.top };
    }

    canvas.addEventListener('mousemove', (evt) => {
      if (state.panning && state.lastPan) {
        const now = { x: evt.clientX, y: evt.clientY };
        const dx = now.x - state.lastPan.x;
        const dy = now.y - state.lastPan.y;
        state.camera.x += dx / state.camera.zoom;
        state.camera.y += dy / state.camera.zoom;
        state.lastPan = now;
        render();
        return;
      }
      updatePreviewFromPointer(evt.clientX, evt.clientY);
    });

    canvas.addEventListener('mousedown', (evt) => {
      if (evt.button === 1) {
        evt.preventDefault();
        state.panning = true;
        state.lastPan = { x: evt.clientX, y: evt.clientY };
      }
    });

    canvas.addEventListener('mouseup', (evt) => {
      if (evt.button === 1) {
        state.panning = false;
        state.lastPan = null;
      }
    });

    canvas.addEventListener('mouseleave', () => {
      state.panning = false;
      state.lastPan = null;
    });

    canvas.addEventListener('click', (evt) => {
      if (evt.button !== 0) return;
      const rect = canvas.getBoundingClientRect();
      const world = screenToWorld({ x: evt.clientX - rect.left, y: evt.clientY - rect.top });
      if (!state.isDrawing) {
        beginPolyline(world);
      } else {
        addSegment(world);
      }
    });


    canvas.addEventListener('wheel', (evt) => {
      evt.preventDefault();
      const mouse = pointerPosition(evt);
      const before = screenToWorld(mouse);
      const factor = evt.deltaY < 0 ? 1.08 : 0.92;
      state.camera.zoom = clamp(state.camera.zoom * factor, 0.2, 5);
      const after = screenToWorld(mouse);
      state.camera.x += before.x - after.x;
      state.camera.y += before.y - after.y;
      render();
    }, { passive: false });

    document.addEventListener('keydown', (evt) => {
      if (evt.key === 'Enter') {
        if (state.isDrawing && state.toolMode === 'polyline') finishPolyline();
      } else if (evt.key === 'Escape') {
        if (state.isDrawing) finishPolyline();
      }
      if ((evt.ctrlKey || evt.metaKey) && evt.key.toLowerCase() === 'z') {
        evt.preventDefault();
        els.undoBtn.click();
      }
    });

    els.lineBtn.addEventListener('click', () => {
      state.toolMode = 'line';
      if (state.isDrawing) finishPolyline('Switched to the Line tool.');
      render();
    });
    els.polylineBtn.addEventListener('click', () => {
      state.toolMode = 'polyline';
      if (state.isDrawing && state.currentPolylineStyle === 'line') finishPolyline('Switched to the Polyline tool.');
      render();
    });
    els.undoBtn.addEventListener('click', () => {
      if (!state.segments.length) return;
      if (state.isDrawing) {
        if (state.segments.length > state.polylineStartIndex) {
          state.segments.pop();
          if (state.segments.length > state.polylineStartIndex) {
            state.currentPolylineStart = { ...state.segments[state.segments.length - 1].end };
          } else if (state.polylineSeedPoint) {
            state.currentPolylineStart = { ...state.polylineSeedPoint };
          }
          state.previewEnd = state.currentPolylineStart;
        }
      } else {
        state.segments.pop();
      }
      render();
    });
    els.clearBtn.addEventListener('click', () => {
      state.segments = [];
      finishPolyline();
      state.camera = { x: 0, y: 0, zoom: 1 };
      setStatus('Drawing cleared. Ready for a new piping layout.');
      render();
    });
    els.centerBtn.addEventListener('click', recenter);
    els.printBtn.addEventListener('click', () => {
      buildPrintSheet();
      window.print();
    });

    els.pipeSize.addEventListener('input', () => {
      state.defaultPipeSize = Number(els.pipeSize.value);
      els.pipeSizeValue.value = state.defaultPipeSize;
      render();
    });
    els.pipeSizeValue.addEventListener('input', () => {
      state.defaultPipeSize = clamp(Number(els.pipeSizeValue.value || 18), 1, 42);
      els.pipeSize.value = state.defaultPipeSize;
      render();
    });
    els.gridStep.addEventListener('input', () => {
      state.gridStep = clamp(Number(els.gridStep.value || 24), 8, 80);
      render();
    });
    els.polylineStyle.addEventListener('input', () => {
      state.selectedPolylineStyle = els.polylineStyle.value;
      render();
    });

    function getBounds(segments) {
      if (!segments.length) return null;
      const pts = [];
      segments.forEach(s => { pts.push(s.start, s.end); });
      return {
        minX: Math.min(...pts.map(p => p.x)),
        maxX: Math.max(...pts.map(p => p.x)),
        minY: Math.min(...pts.map(p => p.y)),
        maxY: Math.max(...pts.map(p => p.y))
      };
    }

    function buildPrintSheet() {
      els.tbProject.textContent = (els.projectTitle.value || 'ISOMETRIC PIPING').toUpperCase();
      els.tbRev.textContent = (els.revision.value || '0').toUpperCase();
      els.tbDwg.textContent = (els.drawingNumber.value || 'ISO-001').toUpperCase();
      els.tbScale.textContent = (els.sheetScale.value || 'NTS').toUpperCase();
      els.tbBy.textContent = (els.drawnBy.value || 'USER').toUpperCase();
      els.tbDate.textContent = new Date().toLocaleDateString();

      const w = 1200;
      const h = 700;
      const pad = 55;
      const bounds = getBounds(state.segments);

      let svg = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
      svg += `<defs>
        <linearGradient id="pipeGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#efefef" />
          <stop offset="35%" stop-color="#cccccc" />
          <stop offset="72%" stop-color="#9b9b9b" />
          <stop offset="100%" stop-color="#656565" />
        </linearGradient>
        <marker id="printArrow" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
          <path d="M0,0 L8,4 L0,8 Z" fill="#111" />
        </marker>
      </defs>`;

      // frame note line
      svg += `<text x="18" y="26" font-size="14" font-family="Arial" letter-spacing="2">NORTH FIXED TO TOP-RIGHT</text>`;
      svg += `<circle cx="1040" cy="60" r="34" fill="none" stroke="#444" stroke-width="1.4" />`;
      svg += `<path d="M1018 74 L1058 50" stroke="#111" stroke-width="2" marker-end="url(#printArrow)" />`;
      svg += `<text x="1061" y="42" font-size="14" font-family="Arial" font-weight="700">N</text>`;

      if (!bounds) {
        svg += `<text x="${w / 2}" y="${h / 2}" text-anchor="middle" font-size="28" fill="#666" font-family="Arial">NO PIPING DRAWN</text>`;
      } else {
        const bw = Math.max(60, bounds.maxX - bounds.minX);
        const bh = Math.max(60, bounds.maxY - bounds.minY);
        const scale = Math.min((w - pad * 2) / bw, (h - pad * 2) / bh);
        const cx = (bounds.minX + bounds.maxX) / 2;
        const cy = (bounds.minY + bounds.maxY) / 2;

        function map(p) {
          return {
            x: (p.x - cx) * scale + w / 2,
            y: (p.y - cy) * scale + h / 2
          };
        }

        const renderModel = buildRenderModel(state.segments);

        state.segments.forEach((seg, index) => {
          const trimmed = getTrimmedSegment(seg, renderModel.plans[index]);
          if (!trimmed) return;

          const a = map(trimmed.start);
          const b = map(trimmed.end);
          const vx = b.x - a.x;
          const vy = b.y - a.y;
          const L = Math.hypot(vx, vy) || 1;
          const tx = vx / L;
          const ty = vy / L;
          const nx = -ty;
          const ny = tx;
          const r = (trimmed.size * scale) / 2;

          const p1 = `${a.x + nx * r},${a.y + ny * r}`;
          const p2 = `${b.x + nx * r},${b.y + ny * r}`;
          const p3 = `${b.x - nx * r},${b.y - ny * r}`;
          const p4 = `${a.x - nx * r},${a.y - ny * r}`;

          svg += `<polygon points="${p1} ${p2} ${p3} ${p4}" fill="url(#pipeGrad)" stroke="#111" stroke-width="1" />`;
          svg += `<line x1="${a.x + nx * r}" y1="${a.y + ny * r}" x2="${b.x + nx * r}" y2="${b.y + ny * r}" stroke="#fff" stroke-opacity="0.65" stroke-width="1.3" />`;
          svg += `<line x1="${a.x - nx * r}" y1="${a.y - ny * r}" x2="${b.x - nx * r}" y2="${b.y - ny * r}" stroke="#111" stroke-opacity="0.35" stroke-width="1.3" />`;
          if (trimmed.capStart) svg += `<ellipse cx="${a.x}" cy="${a.y}" rx="${r}" ry="${Math.max(3, r * 0.45)}" transform="rotate(${Math.atan2(vy, vx) * 180 / Math.PI} ${a.x} ${a.y})" fill="url(#pipeGrad)" stroke="#111" stroke-width="1" />`;
          if (trimmed.capEnd) svg += `<ellipse cx="${b.x}" cy="${b.y}" rx="${r}" ry="${Math.max(3, r * 0.45)}" transform="rotate(${Math.atan2(vy, vx) * 180 / Math.PI} ${b.x} ${b.y})" fill="url(#pipeGrad)" stroke="#111" stroke-width="1" />`;
          svg += `<line x1="${a.x}" y1="${a.y}" x2="${b.x}" y2="${b.y}" stroke="#666" stroke-opacity="0.25" stroke-dasharray="4 4" />`;
        });

        renderModel.elbows.forEach(elbow => {
          const mappedElbow = {
            ...elbow,
            from: map(elbow.from),
            joint: map(elbow.joint),
            to: map(elbow.to)
          };
          const { p1, p2, c1, c2 } = elbowBezierControls(mappedElbow, true);
          const width = Math.max(1, elbow.size * scale);
          const path = `M ${p1.x} ${p1.y} C ${c1.x} ${c1.y} ${c2.x} ${c2.y} ${p2.x} ${p2.y}`;
          svg += `<path d="${path}" fill="none" stroke="#111" stroke-width="${width + 1.2}" stroke-linecap="round" stroke-linejoin="round" />`;
          svg += `<path d="${path}" fill="none" stroke="url(#pipeGrad)" stroke-width="${width}" stroke-linecap="round" stroke-linejoin="round" />`;
          svg += `<path d="${path}" fill="none" stroke="#fff" stroke-opacity="0.18" stroke-width="${Math.max(1, width * 0.2)}" stroke-linecap="round" stroke-linejoin="round" />`;
        });
      }

      svg += `</svg>`;
      els.printSvgWrap.innerHTML = svg;
    }

    window.addEventListener('resize', resize);
    resize();
    render();
  </script>
</body>
</html>
