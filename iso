  .sheet-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; }
  .panel { border: 1px solid #64748b; padding: 8px; background: #fff; }
  .panel h3 { margin: 0 0 8px; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; }
