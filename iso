  .title-cell { min-height: 72px; border-right: 1px solid #0f172a; padding: 8px 10px; font-size: 12px; }
  .title-cell:last-child { border-right: 0; }
  .title-main { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .meta { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 6px 12px; font-size: 12px; }
  .bom-table { width: 100%; border-collapse: collapse; font-size: 10px; }
  .bom-table th, .bom-table td { border: 1px solid #94a3b8; padding: 4px 6px; text-align: left; vertical-align: top; }
  .bom-table th { background: #e2e8f0; }
  .small { font-size: 11px; color: #334155; }
  @page { size: landscape; margin: 0.35in; }
  @media print {
    body { background: #fff; }
    .toolbar { display: none; }
    .sheet { margin: 0; border: 0; box-shadow: none; width: auto; min-height: auto; padding: 0; }
  }
</style>
</head>
<body>
  <div class="toolbar">
    <button class="print" onclick="window.print()">Print</button>
    <button class="close" onclick="window.close()">Close</button>
  </div>
  <div class="sheet">
    <div class="sheet-grid">
      <div class="panel">
        <h3>Isometric View</h3>
        ${isoSvg}
      </div>
      <div class="panel">
        <h3>Material Summary</h3>
        ${buildBomHtmlTable(16)}
        <div class="small" style="margin-top:8px;">Auto fittings shown on this sheet are derived from shared pipe endpoints when auto-join is enabled.</div>
      </div>
    </div>

    <div class="ortho-grid" style="margin-top:14px;">
      <div class="panel">
        <h3>Top View (X-Y)</h3>
        ${topSvg}
      </div>
      <div class="panel">
        <h3>Front View (X-Z)</h3>
        ${frontSvg}
      </div>
      <div class="panel">
        <h3>Right View (Y-Z)</h3>
        ${rightSvg}
      </div>
      <div class="panel">
        <h3>Notes</h3>
        <div class="small">Pipe dimensions are centerline grid units. Pipe thickness in the print views is diagrammatic. Use exported JSON or DXF-like output for data exchange and the BOM CSV for tabular material summaries.</div>
      </div>
    </div>

    <div class="title-block">
      <div class="title-cell">
        <div class="title-main">${escapeHtml(state.projectName)}</div>
