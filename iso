      </div>
      <div class="title-cell">
        <div class="meta">
          <div><strong>Date</strong></div><div>${escapeHtml(dateStamp)}</div>
          <div><strong>Pipes</strong></div><div>${state.pipes.length}</div>
          <div><strong>Components</strong></div><div>${state.components.length}</div>
          <div><strong>Auto fittings</strong></div><div>${autoCount}</div>
        </div>
      </div>
      <div class="title-cell">
        <div class="meta">
          <div><strong>Scale</strong></div><div>Not to scale</div>
          <div><strong>Units</strong></div><div>Grid</div>
          <div><strong>Diameter default</strong></div><div>${Number(state.defaultDiameter).toFixed(2)}</div>
          <div><strong>Grid px</strong></div><div>${state.grid}</div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>`;
      }

      function openPrintSheet() {
        const win = window.open('', '_blank');
        if (!win) {
          updateStatus('Pop-up blocked. Allow pop-ups for this page to open the print sheet.');
          return;
        }
        win.document.open();
        win.document.write(buildPrintSheetHtml());
        win.document.close();
        updateStatus('Opened print sheet layout in a new tab/window.');
      }

      function attachEvents() {
        els.modeButtons.forEach(btn => btn.addEventListener('click', () => setMode(btn.dataset.mode)));

        els.pipeDiameter.addEventListener('input', () => {
          state.defaultDiameter = Number(els.pipeDiameter.value);
          els.pipeDiameterValue.textContent = `${state.defaultDiameter.toFixed(2)} grid`;
          render();
        });

        els.gridScale.addEventListener('input', () => {
          state.grid = Number(els.gridScale.value);
          els.gridScaleValue.textContent = `${state.grid} px`;
          render();
        });

        els.pipeColor.addEventListener('change', () => {
          state.defaultPipeColor = els.pipeColor.value.trim() || '#7dd3fc';
          render();
        });

        els.workingZ.addEventListener('change', () => {
          state.workingZ = Math.round(Number(els.workingZ.value) || 0);
          els.workingZ.value = String(state.workingZ);
          render();
        });

        els.snapToggle.addEventListener('change', () => {
          state.snapEnabled = !!els.snapToggle.checked;
          render();
        });

        els.dimensionsToggle.addEventListener('change', () => {
          state.showDimensions = !!els.dimensionsToggle.checked;
          render();
        });

        els.autoJoinToggle.addEventListener('change', () => {
          state.autoJoinEnabled = !!els.autoJoinToggle.checked;
          render();
        });

        els.endRunBtn.addEventListener('click', () => {
          state.drawingStart = null;
          state.previewEnd = null;
          render();
          updateStatus('Pipe run ended.');
        });

        els.deleteSelectionBtn.addEventListener('click', deleteSelection);
        els.applySelectionBtn.addEventListener('click', applySelectionChanges);
        els.clearSelectionBtn.addEventListener('click', () => {
          state.selected = null;
          state.dragState = null;
          refreshSelectionInfo();
          render();
          updateStatus('Selection cleared.');
        });

        els.saveComponentBtn.addEventListener('click', () => saveComponent(false));
        els.updateComponentBtn.addEventListener('click', () => saveComponent(true));
        els.deleteComponentBtn.addEventListener('click', deleteActiveLibraryItem);

        els.projectName.addEventListener('change', () => state.projectName = els.projectName.value.trim() || 'Untitled Project');
        els.saveProjectBtn.addEventListener('click', saveProjectToBrowser);
        els.loadProjectBtn.addEventListener('click', loadProjectFromBrowser);
        els.newProjectBtn.addEventListener('click', resetProject);
        els.exportJsonBtn.addEventListener('click', exportJson);
        els.importJsonBtn.addEventListener('click', () => els.importJsonInput.click());
        els.importJsonInput.addEventListener('change', evt => {
          const file = evt.target.files?.[0];
          if (file) importJsonFile(file);
          evt.target.value = '';
        });
        els.exportBomBtn.addEventListener('click', exportBomCsv);
        els.exportCadBtn.addEventListener('click', exportCadText);
        els.printSheetBtn.addEventListener('click', openPrintSheet);

        els.svg.addEventListener('pointerdown', handlePointerDown);
        window.addEventListener('pointermove', handlePointerMove);
        window.addEventListener('pointerup', handlePointerUp);
        els.svg.addEventListener('wheel', handleWheel, { passive: false });
        els.svg.addEventListener('dblclick', evt => {
          const hit = hitTest(canvasPoint(evt).x, canvasPoint(evt).y);
          if (!hit) centerView();
        });

        window.addEventListener('keydown', evt => {
          if (evt.key === 'Escape') {
            state.drawingStart = null;
            state.previewEnd = null;
            state.dragState = null;
            render();
            updateStatus('Cancelled current draw action.');
          }
          if ((evt.key === 'Delete' || evt.key === 'Backspace') && state.selected) {
            evt.preventDefault();
            deleteSelection();
          }
          if (evt.key.toLowerCase() === 'v') setMode('select');
          if (evt.key.toLowerCase() === 'p') setMode('pipe');
          if (evt.key.toLowerCase() === 'c') setMode('component');
          if (evt.key.toLowerCase() === 'h') setMode('pan');
          if (evt.key === '[') {
            state.workingZ -= 1;
            syncInputs();
            render();
          }
          if (evt.key === ']') {
            state.workingZ += 1;
            syncInputs();
            render();
          }
        });

        window.addEventListener('resize', () => render());
      }

      function init() {
        loadStoredState();
        if (!state.activeLibraryId && state.library.length) {
          state.activeLibraryId = state.library[0].id;
          populateComponentEditor(state.library[0]);
        }
        state.originX = Math.max(420, els.workspace.clientWidth * 0.54);
        state.originY = Math.max(260, els.workspace.clientHeight * 0.55);
        syncInputs();
        renderLibrary();
        attachEvents();
        render();
      }

      init();
    })();
  
  </script>
</body>
</html>
